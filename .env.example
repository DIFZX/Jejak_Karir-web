# Copy this file to .env and replace every placeholder with local values.
APP_TIMEZONE=Asia/Jakarta
DB_DRIVER=mysql

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=replace_with_your_database_password

# Optional: leave both empty to disable automatic initial-account creation.
INITIAL_USERNAME=your_initial_username
INITIAL_PASSWORD=replace_with_a_strong_unique_password

# Required only when DB_DRIVER=pgsql.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_DB_URL=postgresql://your_pooler_user:your_database_password@your-session-pooler-host:5432/postgres
